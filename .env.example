# === BINANCE ===
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=false  # set true for paper trading

# === GROQ (primary AI) ===
# Comma-separated list of keys for rotation/rate-limit handling
GROQ_API_KEYS=gsk_key_1,gsk_key_2,gsk_key_3,gsk_key_4,gsk_key_5
GROQ_MODEL=llama-3.3-70b-versatile

# === OPENROUTER (Tier 2 — free models, no credit card needed) ===
# Get free key at: https://openrouter.ai/keys
# Add multiple keys: OPENROUTER_API_KEYS=key1,key2,key3
OPENROUTER_API_KEYS=sk-or-v1-your_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_HOURLY_LIMIT=40

# === BROWSER AI (Tier 3 — ChatGPT or Gemini web, completely free) ===
# ONE-TIME SETUP: python agents/browser_ai.py --login gemini
#   chatgpt  → uses https://chatgpt.com  (GPT-4o free tier)
#   gemini   → uses https://gemini.google.com  (Gemini 2.0 free)
#   off      → disabled
BROWSER_AI_PROVIDER=gemini
BROWSER_AI_HEADED=false          # set true to see the browser window (debug)

# === GEMINI API (Tier 4 — paid, last resort only) ===
# Leave blank to skip (browser Gemini is free anyway).
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_HOURLY_LIMIT=20         # max Gemini API calls per hour (sliding window)

# === SUPABASE ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# === OPTIONAL FREE DATA APIS ===
CRYPTOPANIC_API_KEY=your_key_here   # free at cryptopanic.com
# Fear & Greed Index: no key needed (alternative.me)
# Binance public endpoints: no key needed for OHLCV

# === AGENT SETTINGS ===
# Full pair pool — selector picks SCAN_PAIRS_PER_CYCLE of these per cycle, rotating through all
TRADING_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,DOTUSDT,LINKUSDT,LTCUSDT,NEARUSDT,ATOMUSDT,INJUSDT,APTUSDT,SUIUSDT,TONUSDT,SEIUSDT,ARBUSDT,OPUSDT,POLUSDT,STXUSDT,LDOUSDT,AAVEUSDT,UNIUSDT,MKRUSDT,ENAUSDT,PENDLEUSDT,FETUSDT,GRTUSDT,WLDUSDT,PYTHUSDT,FILUSDT,RUNEUSDT,TIAUSDT,ONDOUSDT,1000PEPEUSDT,WIFUSDT,1000FLOKIUSDT,JUPUSDT,ORDIUSDT,JTOUSDT,IMXUSDT
SCAN_PAIRS_PER_CYCLE=5                # how many pairs to AI-scan each cycle (smart rotation)
CYCLE_INTERVAL_SECONDS=30             # seconds between cycles
MIN_CONFIDENCE=80                     # % confidence required to trade
MAX_POSITION_PCT=40                   # max % of balance per trade
STOP_LOSS_PCT=0.5                     # stop loss % (×20 leverage = -10% real)
TAKE_PROFIT_PCT=0.8                   # take profit % (×20 leverage = +16% real, ~1.6:1 R:R)
MAX_DAILY_LOSS_PCT=-6.0               # halt trading if daily PnL drops below this %
DRY_RUN=true                          # ALWAYS start with true!
LOG_LEVEL=INFO

# === TRADE MODE ===
TRADE_MODE=futures                    # "spot" or "futures"
FUTURES_LEVERAGE=20                   # 1-20x leverage (only used when TRADE_MODE=futures)

# === TELEGRAM ALERTS (optional) ===
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  → find "chat":{"id":...}
TELEGRAM_BOT_TOKEN=                   # e.g. 123456789:ABCdef...
TELEGRAM_CHAT_ID=                     # e.g. 123456789





